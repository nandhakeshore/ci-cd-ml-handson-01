    "import pandas as pd\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "\n",
    "# Create dummy data\n",
    "data = pd.DataFrame({\n",
    "    \"x\": [1, 2, 3, 4],\n",
    "    \"y\": [0, 1, 0, 1]\n",
    "})\n",
    "\n",
    "# Train model\n",
    "model = LogisticRegression()\n",
    "model.fit(data[[\"x\"]], data[\"y\"])\n",
    "\n",
    "print(\"Model trained successfully\")"
   ]
